package logging;

import java.util.List;
import java.util.Map;

import com.mendix.core.objectmanagement.member.MendixObjectReference;
import com.mendix.core.objectmanagement.member.MendixObjectReferenceSet;
import com.mendix.logging.ILogNode;
import com.mendix.systemwideinterfaces.core.IContext;
import com.mendix.systemwideinterfaces.core.IMendixIdentifier;
import com.mendix.systemwideinterfaces.core.IMendixObject;
import com.mendix.systemwideinterfaces.core.IMendixObjectMember;

import communitycommons.proxies.LogLevel;

/**
 * Shared, side-effect-free helpers for diagnostic logging of Mendix objects.
 * Reused by the LogObjectState and LogWorkflowContext Java actions.
 */
public final class LogFormatter {

	public static final int DEFAULT_MAX_LENGTH = 500;

	private LogFormatter() {
	}

	// Guard heavy string building: only Trace/Debug are typically disabled in production.
	public static boolean isEnabled(ILogNode log, LogLevel level) {
		if (level == LogLevel.Trace) {
			return log.isTraceEnabled();
		}
		if (level == LogLevel.Debug) {
			return log.isDebugEnabled();
		}
		return true;
	}

	public static void emit(ILogNode log, LogLevel level, String message) {
		LogLevel lvl = level == null ? LogLevel.Info : level;
		switch (lvl) {
			case Trace:
				log.trace(message);
				break;
			case Debug:
				log.debug(message);
				break;
			case Warning:
				log.warn(message);
				break;
			case Error:
				log.error(message);
				break;
			case Critical:
				log.critical(message);
				break;
			case Info:
			default:
				log.info(message);
				break;
		}
	}

	public static String truncate(String value, int maxLength) {
		if (value == null) {
			return "<null>";
		}
		int max = maxLength <= 0 ? DEFAULT_MAX_LENGTH : maxLength;
		if (value.length() <= max) {
			return value;
		}
		return value.substring(0, max) + "...(+" + (value.length() - max) + " chars)";
	}

	public static String describeObject(IContext context, IMendixObject object, int maxLength) {
		if (object == null) {
			return "<null object>";
		}
		StringBuilder sb = new StringBuilder(object.getType()).append("[id=");
		sb.append(object.getId() == null ? "new" : object.getId().toLong()).append("] {");
		Map<String, ? extends IMendixObjectMember<?>> members = object.getMembers(context);
		boolean first = true;
		for (Map.Entry<String, ? extends IMendixObjectMember<?>> entry : members.entrySet()) {
			if (!first) {
				sb.append(", ");
			}
			first = false;
			sb.append(entry.getKey()).append('=').append(describeMember(context, entry.getValue(), maxLength));
		}
		return sb.append('}').toString();
	}

	// Logs only the user's display name + id, never the full member set, to avoid leaking PII.
	public static String describeUser(IContext context, IMendixObject user) {
		if (user == null) {
			return "<none>";
		}
		Object name = null;
		try {
			name = user.getValue(context, "Name");
		} catch (Exception ignored) {
		}
		String id = user.getId() == null ? "?" : String.valueOf(user.getId().toLong());
		return (name == null ? "user" : String.valueOf(name)) + "(" + id + ")";
	}

	private static String describeMember(IContext context, IMendixObjectMember<?> member, int maxLength) {
		try {
			if (member instanceof MendixObjectReference) {
				IMendixIdentifier id = ((MendixObjectReference) member).getValue(context);
				return id == null ? "<empty ref>" : "ref(" + id.toLong() + ")";
			}
			if (member instanceof MendixObjectReferenceSet) {
				List<IMendixIdentifier> ids = ((MendixObjectReferenceSet) member).getValue(context);
				return (ids == null || ids.isEmpty()) ? "<empty list>" : "list[" + ids.size() + "]";
			}
			Object value = member.getValue(context);
			if (value == null) {
				return "<null>";
			}
			String text = String.valueOf(value);
			return text.isEmpty() ? "<empty>" : truncate(text, maxLength);
		} catch (Exception e) {
			return "<error:" + e.getClass().getSimpleName() + ">";
		}
	}
}
